            --bg-grad: linear-gradient(135deg, #2d0000 0%, #000000 50%, #001a00 100%);
            --main-btn: linear-gradient(90deg, #1a2a6c, #b21f1f, #004400);
            --sub-btn: linear-gradient(45deg, #FFD700, #FF4500);
            --gold: #FFD700;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }

        body { background: var(--bg-grad); background-attachment: fixed; color: #fff; padding: 10px; min-height: 100vh; text-align: center; }

        #rainCanvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }

        header {
            position: relative; z-index: 10; background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px); border-radius: 15px; padding: 15px; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.1);
        }
        #clock { font-size: 1.5rem; font-weight: bold; color: var(--gold); }
        
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; font-size: 0.85rem; }
        .info-box { background: rgba(0,0,0,0.3); padding: 8px; border-radius: 10px; border: 1px solid rgba(255,215,0,0.2); }
        .prayer-time { color: var(--gold); font-weight: bold; }

        .container { position: relative; z-index: 10; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 15px; }
        .card { background: rgba(0, 0, 0, 0.7); border-radius: 15px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
        .main-btn { width: 100%; padding: 18px; background: var(--main-btn); border: none; color: white; font-size: 1.1rem; font-weight: 700; cursor: pointer; }

        .content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; background: rgba(0, 0, 0, 0.6); }
        .link-grid { padding: 15px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

        .sub-btn {
            background: var(--sub-btn); color: #000; text-decoration: none; padding: 10px; border-radius: 8px;
            font-size: 0.85rem; font-weight: 800; display: flex; align-items: center; justify-content: center; height: 45px;
            transition: 0.2s;
        }
        .sub-btn:hover { opacity: 0.9; transform: scale(1.02); }

        .tool-box { padding: 20px; }
        .calc-input { width: 95%; padding: 12px; margin-bottom: 10px; border-radius: 8px; border: none; background: #111; color: var(--gold); text-align: center; }
        
        .mode-container { display: flex; gap: 10px; justify-content: center; margin-bottom: 15px; }
        .mode-btn { padding: 8px 15px; cursor: pointer; border: none; border-radius: 5px; background: #333; color: #fff; }
        .mode-btn.active { background: var(--gold); color: #000; font-weight: bold; }

        .result-box { background: rgba(255, 215, 0, 0.1); padding: 15px; border-radius: 10px; border: 1px solid var(--gold); margin-top: 15px; }
        #scheduleTable { width: 100%; margin-top: 15px; border-collapse: collapse; font-size: 0.7rem; }
        #scheduleTable th, #scheduleTable td { border: 1px solid rgba(255,215,0,0.3); padding: 5px; text-align: center; }

        footer { margin-top: 40px; padding: 30px; background: #000; border-top: 2px solid var(--gold); }
        .social-btn { text-decoration: none; color: #000; background: var(--gold); padding: 10px 20px; border-radius: 50px; font-weight: bold; display: inline-block; margin: 5px; }
    </style>
</head>
