    <script>
        const canvas = document.getElementById('rainCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const drops = [];
        for(let i=0; i<100; i++) drops.push({x: Math.random()*canvas.width, y: Math.random()*canvas.height, s: Math.random()*5+5});
        function drawRain() {
            ctx.clearRect(0,0,canvas.width, canvas.height); ctx.strokeStyle = 'rgba(174,194,224,0.1)';
            drops.forEach(d => {
                ctx.beginPath(); ctx.moveTo(d.x, d.y); ctx.lineTo(d.x, d.y+15); ctx.stroke();
                d.y += d.s; if(d.y > canvas.height) d.y = -20;
            });
            requestAnimationFrame(drawRain);
        }
        drawRain();

        function toggle(btn) {
            const p = btn.nextElementSibling;
            document.querySelectorAll('.content').forEach(c => { if(c!==p) c.style.maxHeight = null; });
            p.style.maxHeight = p.style.maxHeight ? null : "1200px";
        }

        // অটো লোকেশন ও ডেটা লোড
        function getAutoLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(async (pos) => {
                    const lat = pos.coords.latitude;
                    const lon = pos.coords.longitude;
                    
                    try {
                        const geo = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`);
                        const gData = await geo.json();
                        const place = gData.address.city || gData.address.town || gData.address.village || "সান্তাহার";
                        document.getElementById('userLocation').innerText = place;
                    } catch(e) { document.getElementById('userLocation').innerText = "সান্তাহার"; }

                    updateWeather(lat, lon);
                    updatePrayers(lat, lon);
                }, () => {
                    updateWeather(24.78, 88.99);
                    updatePrayers(24.78, 88.99);
                });
            }
        }

        async function updateWeather(lat, lon) {
            try {
                const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
                const data = await res.json();
                document.getElementById('weather').innerText = `${data.current_weather.temperature}°C`;
            } catch(e) { document.getElementById('weather').innerText = "N/A"; }
        }

        async function updatePrayers(lat, lon) {
            try {
                // Method 1 = University of Islamic Sciences, Karachi (Hanafi)
                // School 1 = Hanafi asr timing
                const res = await fetch(`https://api.aladhan.com/v1/timingsByAddress?address=${lat},${lon}&method=1&school=1`);
                const data = await res.json();
                const t = data.data.timings;
                document.getElementById('fajr').innerText = t.Fajr;
                document.getElementById('dhuhr').innerText = t.Dhuhr;
                document.getElementById('asr').innerText = t.Asr;
                document.getElementById('maghrib').innerText = t.Maghrib;
                document.getElementById('isha').innerText = t.Isha;

                const now = new Date();
                const cur = now.getHours() * 60 + now.getMinutes();
                const pArr = [
                    {n: 'ফজর', t: t.Fajr}, {n: 'জোহর', t: t.Dhuhr}, 
                    {n: 'আসর', t: t.Asr}, {n: 'মাগরিব', t: t.Maghrib}, {n: 'ইশা', t: t.Isha}
                ];
                let next = pArr[0];
                for (let p of pArr) {
                    const [h, m] = p.t.split(':');
                    if (parseInt(h)*60 + parseInt(m) > cur) { next = p; break; }
                }
                document.getElementById('nextPrayer').innerText = `${next.n} (${next.t})`;
            } catch(e) { console.log("Prayer Data Error"); }
        }

        let lMode = 's';
        function setMode(m) {
            lMode = m;
            document.getElementById('mS').classList.toggle('active', m==='s');
            document.getElementById('mC').classList.toggle('active', m==='c');
        }

        function updateLoan() {
            const P = parseFloat(document.getElementById('loanP').value);
            const rateYear = parseFloat(document.getElementById('loanR').value);
            const N = parseInt(document.getElementById('loanN').value);
            if(!P || !rateYear || !N) return;
            const R = rateYear / 1200;
            let emi, totalInt, balance = P;
            const res = document.getElementById('loanRes');
            const table = document.getElementById('scheduleTable');
            const body = document.getElementById('schedBody');
            body.innerHTML = "";
            if(lMode === 's') {
                totalInt = P * (rateYear / 100) * (N / 12);
                emi = (P + totalInt) / N;
            } else {
                emi = P * R * Math.pow(1+R, N) / (Math.pow(1+R, N)-1);
                totalInt = (emi * N) - P;
            }
            res.style.display = 'block'; table.style.display = 'table';
            res.innerHTML = `কিস্তি: <b>${emi.toFixed(2)}</b> টাকা | সুদ: ${totalInt.toFixed(0)} টাকা`;
            for(let i=1; i<=Math.min(N, 12); i++) {
                let interest = lMode === 'c' ? balance * R : (P * (rateYear/100) / 12);
                let principal = emi - interest;
                balance -= principal;
                body.innerHTML += `<tr><td>${i}</td><td>${emi.toFixed(0)}</td><td>${interest.toFixed(0)}</td><td>${principal.toFixed(0)}</td><td>${Math.max(0, balance).toFixed(0)}</td></tr>`;
            }
        }

        function updateAge() {
            const bInput = document.getElementById('birthD').value;
            if(!bInput) return;
            const birth = new Date(bInput);
            const now = new Date();
            let y = now.getFullYear() - birth.getFullYear();
            let m = now.getMonth() - birth.getMonth();
            let d = now.getDate() - birth.getDate();
            if (d < 0) { m--; d += new Date(now.getFullYear(), now.getMonth(), 0).getDate(); }
            if (m < 0) { y--; m += 12; }
            const res = document.getElementById('ageRes');
            res.style.display = 'block';
            res.innerHTML = `বয়স: <b>${y} বছর, ${m} মাস, ${d} দিন</b>`;
        }

        setInterval(() => {
            const n = new Date();
            document.getElementById('clock').innerText = n.toLocaleTimeString();
            document.getElementById('date').innerText = n.toLocaleDateString('en-GB');
        }, 1000);

        getAutoLocation();
    </script>
</body>
</html>
